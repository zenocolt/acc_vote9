# Production environment template for Render/Railway
# Copy this file to your deployment platform environment variables.

NODE_ENV=production

# Render will inject PORT automatically. Keep as fallback for local production run.
PORT=10000

# Required: MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority

# Optional: defaults to vote_starmoon_accounting if omitted
MONGODB_DB_NAME=acc_vote

# Optional: only if using Gemini features
GEMINI_API_KEY=
